# =============================================================================
# Production Environment Configuration
# =============================================================================
# Production values. Override .env with this file for production deployments.
# IMPORTANT: Replace ALL placeholder values with actual secrets before use.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
FLASK_ENV=production
SECRET_KEY=REPLACE-WITH-64-CHAR-RANDOM-SECRET
LOG_LEVEL=WARNING
LOG_FORMAT=json
TZ=UTC

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
POSTGRES_DB=microservices
POSTGRES_USER=appuser
POSTGRES_PASSWORD=REPLACE-WITH-STRONG-PASSWORD
POSTGRES_PORT=5432
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# ---------------------------------------------------------------------------
# Cache (Redis)
# ---------------------------------------------------------------------------
REDIS_PASSWORD=REPLACE-WITH-STRONG-REDIS-PASSWORD
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# API Service
# ---------------------------------------------------------------------------
API_PORT=5000
RATELIMIT_STORAGE_URI=redis://:REPLACE@redis:6379/0

# ---------------------------------------------------------------------------
# Worker Service
# ---------------------------------------------------------------------------
WORKER_PORT=5001
CELERY_WORKER_CONCURRENCY=8
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_TASK_TIME_LIMIT=600
CELERY_TASK_SOFT_TIME_LIMIT=540
CELERY_RESULT_EXPIRES=3600
CELERY_MAX_RETRIES=3
CELERY_RETRY_DELAY=60
WORKER_MAX_TASKS=5000

# ---------------------------------------------------------------------------
# Nginx
# ---------------------------------------------------------------------------
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
NGINX_HEALTH_PORT=8080
SSL_CERT_PATH=/etc/ssl/certs

# ---------------------------------------------------------------------------
# Monitoring
# ---------------------------------------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
FLUENT_PORT=24224

# ---------------------------------------------------------------------------
# Data Directories
# ---------------------------------------------------------------------------
DATA_DIR=/var/lib/microservices/data

# ---------------------------------------------------------------------------
# Email (Production)
# ---------------------------------------------------------------------------
EMAIL_PROVIDER=sendgrid
DEFAULT_FROM_EMAIL=noreply@yourcompany.com
SENDGRID_API_KEY=REPLACE-WITH-SENDGRID-KEY

# ---------------------------------------------------------------------------
# Backup (Production)
# ---------------------------------------------------------------------------
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *
S3_BACKUP_BUCKET=your-backup-bucket
S3_BACKUP_PREFIX=production/backups/
AWS_ACCESS_KEY_ID=REPLACE
AWS_SECRET_ACCESS_KEY=REPLACE
AWS_REGION=us-east-1
