# =============================================================================
# Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values.
# This file serves as documentation for all available configuration options.
# DO NOT commit .env files with real secrets to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-secret-key-min-32-chars
LOG_LEVEL=INFO
LOG_FORMAT=json
TZ=UTC

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
POSTGRES_DB=microservices
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_PORT=5432
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# ---------------------------------------------------------------------------
# Cache (Redis)
# ---------------------------------------------------------------------------
REDIS_PASSWORD=change-me-redis-password
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# API Service
# ---------------------------------------------------------------------------
API_PORT=5000
RATELIMIT_STORAGE_URI=redis://:${REDIS_PASSWORD}@redis:6379/0

# ---------------------------------------------------------------------------
# Worker Service
# ---------------------------------------------------------------------------
WORKER_PORT=5001
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_TASK_TIME_LIMIT=300
CELERY_TASK_SOFT_TIME_LIMIT=240
CELERY_RESULT_EXPIRES=3600
CELERY_MAX_RETRIES=3
CELERY_RETRY_DELAY=60
WORKER_MAX_TASKS=1000

# ---------------------------------------------------------------------------
# Nginx
# ---------------------------------------------------------------------------
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
NGINX_HEALTH_PORT=8080
SSL_CERT_PATH=./certs

# ---------------------------------------------------------------------------
# Monitoring
# ---------------------------------------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
FLUENT_PORT=24224

# ---------------------------------------------------------------------------
# Data Directories
# ---------------------------------------------------------------------------
DATA_DIR=./data

# ---------------------------------------------------------------------------
# Email (Optional)
# ---------------------------------------------------------------------------
EMAIL_PROVIDER=mock
DEFAULT_FROM_EMAIL=noreply@example.com
SENDGRID_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ---------------------------------------------------------------------------
# Backup (Optional)
# ---------------------------------------------------------------------------
BACKUP_RETENTION_DAYS=7
BACKUP_SCHEDULE=0 2 * * *
S3_BACKUP_BUCKET=
S3_BACKUP_PREFIX=backups/
